{
    "name": "ptplugins/filament-auto-filters",
    "description": "Automatic table filters for FilamentPHP based on column definitions",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Premtech Plugins",
            "email": "mihailo@ptplugins.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0 || ^4.0 || ^5.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "PtPlugins\\FilamentAutoFilters\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PtPlugins\\FilamentAutoFilters\\AutoFiltersServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
